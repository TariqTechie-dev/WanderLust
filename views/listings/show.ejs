<% layout("layouts/boilerplate") %>

<div class="row mt-3 mt-md-4 mb-4 g-3">
  <div class="col-12 col-md-8 offset-md-2">
    <h3>
      <%= listing.title %>
    </h3>
  </div>
  
  <div class="col-12 col-md-8 offset-md-2">
    <div class="card h-100 listing-card">
      <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image" />
      <div class="card-body">
        <p class="card-text"> owned by <i>
            <%= listing.owner.username%>
          </i> </p>
        <p class="card-text">
          <%= listing.description %>
        </p>
        <p class="card-text"> &#8360; <%= listing.price.toLocaleString("en-pk") %>
        </p>
        <p class="card-text">
          <%= listing.location %>
        </p>
        <p class="card-text">
          <%= listing.country %>
        </p>
      </div>
      <hr>
    </div>
  </div>

  <!-- btn section for edit and delete only for the owner of the listing -->
  <% if(currentUser && currentUser._id.equals(listing.owner._id)) { %>
  <div class="col-12 col-md-8 offset-md-2">
    <div class="btns">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark flex-grow-1 edit-btn">Edit</a>

      <form method="POST" action="/listings/<%= listing._id %>?_method=delete" class="flex-grow-1">
        <button class="btn btn-dark w-100">Delete</button>
      </form>
    </div>
  </div>
  <% } %>

  <div class="col-12 col-md-8 offset-md-2 mb-3 mt-3">
    <% if(currentUser && !currentUser._id.equals(listing.owner._id)) { %>
    <div class="card shadow-sm p-3 p-md-4">
      <h3 class="mb-3 fs-5 fs-md-6">Share your experience</h3>
      <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">

        <!-- Star Rating -->
        <div class="mb-3">
          <label class="form-label">Rating</label><br>
          <div class="star-rating">
            <label><input type="radio" name="review[rating]" value="1"> ⭐</label>
            <label><input type="radio" name="review[rating]" value="2"> ⭐⭐</label>
            <label><input type="radio" name="review[rating]" value="3" checked> ⭐⭐⭐</label>
            <label><input type="radio" name="review[rating]" value="4"> ⭐⭐⭐⭐</label>
            <label><input type="radio" name="review[rating]" value="5"> ⭐⭐⭐⭐⭐</label>
          </div>
        </div>

        <!-- Comment -->
        <div class="mb-3">
          <label for="comment" class="form-label">Comments</label>
          <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control" required></textarea>
          <div class="invalid-feedback">
            Please submit some comment for review.
          </div>
        </div>

        <button class="btn btn-dark w-100">Submit Review</button>
      </form>
    </div>
    <% } %>

    <!-- All Reviews -->
    <hr class="mt-4 mt-md-5">
    <% if(listing.reviews.length > 0){ %>
    <h4 class="mb-3 fs-6">All Reviews</h4>
    <div class="list-group">
      <% for(let review of listing.reviews) { %>
      <div class="list-group-item">
        <h5 class="mb-1 fs-6">
          <%= review.author.username %>
        </h5>
        <p class="mb-1 fs-7">
          <%= review.comment %>
        </p>
        <small class="text-muted">
          <% for(let i=0; i<review.rating; i++){ %> ⭐ <% } %>
          | Posted on <%= review.createdAt.toDateString() %>
        </small>
        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mt-2">
          <button class="btn btn-sm btn-outline-danger">Delete</button>
        </form>
      </div>
      <% } %>
    </div>  <% } %>
  </div>
  
  <div class="col-12 col-md-8 offset-md-2 mb-3">
    <h3 class="mb-3 fs-5 fs-md-6">Where you'll be</h3>
    <div id="map" data-location="<%= [listing.location, listing.country].filter(Boolean).join(', ') %>" data-title="<%= listing.title %>"></div>
  </div>
</div>

