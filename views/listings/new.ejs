<% layout("layouts/boilerplate") %>

<div class="row">
  <div class="col-12 col-sm-10 col-md-8 offset-sm-1 offset-md-2">
    <br><br>
    <h1>Create New Listing</h1>
    <form method="post" action="/listings"  novalidate class="needs-validation" enctype="multipart/form-data">

      <div class="md-3">
          <label for="title" class="form-label">Title</label>
          <input type="text" name="listing[title]" id="title" placeholder="Enter your title" required class="form-control">
          <div class="valid-feedback"> Title look good</div>
          <div class="invalid-feedback"> Please provide a title</div>
      </div>


      <div class="md-3">
          <label for="description" class="form-label">Description</label>
          <textarea name="listing[description]" id="description" placeholder="Enter your description" required class="form-control"></textarea>
            <div class="valid-feedback"> Description look good</div>
            <div class="invalid-feedback"> Please provide a description</div>
      </div>

     
      <div class="md-3">
          <label for="image" class="form-label">upload listing Image</label>
          <input type="file" name="listing[image]" id="image"   class="form-control">
            <!-- <div class="valid-feedback"> Image link look good</div> -->
            <!-- <div class="invalid-feedback"> Please provide an image an Image</div> -->
             required
      </div>

      <div class="row">
        <div class="md-3 col-12 col-md-4">
           <label for="price" class="form-label">Price</label>
           <input type="number" name="listing[price]" id="price" placeholder="Enter your price" min="0" required class="form-control">
            <div class="valid-feedback"> Price look good</div>
            <div class="invalid-feedback"> Please provide a valid price</div>
        </div>

        <div class="md-3 col-12 col-md-8">
            <label for="location" class="form-label">Location</label>
            <input type="text" name="listing[location]" id="location" placeholder="Enter location" required class="form-control">
              <div class="valid-feedback"> Location look good</div>
              <div class="invalid-feedback"> Please provide a location</div>
        </div>

            <div class="md-3 col-12">
              <label for="country" class="form-label">Country</label>
              <input type="text" name="listing[country]" id="country" placeholder="Enter country" required class="form-control">
              <div class="valid-feedback"> country look good</div>
              <div class="invalid-feedback"> Please provide a country name</div>
            </div>
      </div>


     <br>
      <button type="submit" class="btn btn-dark add-btn w-100 w-md-auto">Add</button>
      <br><br>
    </form>
  </div>
</div>